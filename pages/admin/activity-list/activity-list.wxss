.page {
  padding-bottom: 40rpx;
}

.admin-hero,
.admin-card {
  padding: 30rpx;
}

.admin-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.admin-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.admin-list-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.admin-item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.admin-item-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.admin-item-desc {
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #4b5563;
}

.admin-list-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.admin-fee {
  font-size: 30rpx;
  font-weight: 700;
  color: #7c3aed;
}

.admin-actions {
  display: flex;
  gap: 16rpx;
}

.admin-mini-button {
  min-width: 128rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  padding: 0 18rpx;
}

.admin-mini-button::after,
.admin-small-button::after {
  border: none;
}
