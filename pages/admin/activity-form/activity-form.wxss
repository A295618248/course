.page {
  padding-bottom: 40rpx;
}

.admin-hero,
.admin-form {
  padding: 32rpx;
}

.admin-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.admin-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.7;
}

.field-row {
  display: flex;
  gap: 18rpx;
}

.field-half {
  flex: 1;
}

.status-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.status-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 24rpx;
}

.status-chip.active {
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #ffffff;
}

.upload-preview {
  width: 100%;
  height: 260rpx;
  border-radius: 22rpx;
  margin-bottom: 16rpx;
}

.submit-button {
  margin-top: 12rpx;
}
