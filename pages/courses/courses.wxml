<view class="page">
  <view class="card hero-card">
    <view class="hero-title">体系化艺术课程</view>
    <view class="hero-desc">围绕启蒙、兴趣培养与进阶提升，按年龄段和学习目标设计课程内容。</view>
  </view>

  <scroll-view scroll-x class="filter-row" show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="*this"
      class="filter-chip {{activeCategory === item ? 'filter-chip--active' : ''}}"
      data-category="{{item}}"
      bindtap="handleCategoryTap"
    >
      {{item}}
    </view>
  </scroll-view>

  <view class="section-header">
    <view>
      <view class="section-title">课程列表</view>
      <view class="section-subtitle">共 {{filteredCourses.length}} 门课程</view>
    </view>
  </view>

  <view>
    <view class="card course-card" wx:for="{{filteredCourses}}" wx:key="id">
      <view class="course-top">
        <view>
          <view class="course-title">{{item.title}}</view>
          <view class="course-meta">{{item.category}} · {{item.ageRange}}</view>
        </view>
        <view class="tag">{{item.classSize}}</view>
      </view>

      <view class="course-summary">{{item.summary}}</view>

      <view class="course-tags">
        <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
      </view>

      <view class="course-footer">
        <view>
          <view class="price">{{item.priceText}}</view>
          <view class="course-meta">{{item.schedule}}</view>
        </view>
        <view class="action-group">
          <button class="action-button action-button--ghost" size="mini" data-id="{{item.id}}" catchtap="openCourseDetail">详情</button>
          <button class="action-button action-button--primary" size="mini" data-id="{{item.id}}" catchtap="goSignup">报名</button>
        </view>
      </view>
    </view>
  </view>
</view>
