.hero-card,
.cta-card {
  padding: 32rpx;
}

.course-title {
  margin-top: 14rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.course-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #4b5563;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.meta-item {
  padding: 26rpx;
}

.meta-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.detail-list {
  display: grid;
  gap: 18rpx;
}

.detail-row {
  display: flex;
  gap: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #374151;
}

.detail-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #7c3aed;
  flex-shrink: 0;
}

.cta-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.cta-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.cta-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.cta-button {
  min-width: 220rpx;
}
