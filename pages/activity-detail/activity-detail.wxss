.hero {
  padding: 32rpx;
}

.hero__top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.hero__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.5;
}

.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  align-items: center;
}

.hero__meta-text {
  font-size: 24rpx;
  color: #6b7280;
}

.hero__desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #4b5563;
}

.hero__info {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.hero__info-item {
  padding: 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.hero__info-label {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
}

.hero__info-value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.section-card {
  padding: 28rpx;
  margin-top: 24rpx;
}

.section-desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: #4b5563;
}

.agenda-list {
  display: grid;
  gap: 18rpx;
}

.agenda-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.agenda-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #7c3aed;
  flex-shrink: 0;
}

.agenda-text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.7;
  color: #374151;
}

.notice-line {
  font-size: 26rpx;
  line-height: 1.8;
  color: #4b5563;
  margin-bottom: 10rpx;
}

.footer-space {
  height: 20rpx;
}

.footer-bar {
  position: sticky;
  bottom: 24rpx;
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.footer-bar__label {
  font-size: 22rpx;
  color: #6b7280;
}

.footer-bar__value {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.footer-bar .button-primary {
  min-width: 220rpx;
}
